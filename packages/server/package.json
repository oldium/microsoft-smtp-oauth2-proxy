{
  "name": "@ms-smtp/server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "test-send-auth": "./dist/bin/test-send-auth.js",
    "test-send-email": "./dist/bin/test-send-email.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "cross-env NODE_ENV=production tsc --project ./tsconfig.bin.json && cross-env NODE_ENV=production tsc --project ./tsconfig.src.json",
    "clean": "rimraf ./dist"
  },
  "exports": {
    "./routes": {
      "development": "./src/routes/index.ts",
      "default": "./dist/routes/index.js"
    },
    "./*": {
      "development": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "dependencies": {
    "@ms-smtp/common": "0.0.0",
    "@ms-smtp/lib": "0.0.0",
    "cookies-next": "^6.1.1",
    "email-addresses": "^5.0.0",
    "express": "^5.2.1",
    "ipaddr.js": "^2.3.0",
    "is-base64": "^1.1.0",
    "lodash": "^4.17.23",
    "nocache": "^4.0.0",
    "tiny-typed-emitter": "^2.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/is-base64": "^1.1.3",
    "@types/lodash": "^4.17.23",
    "@types/smtp-server": "^3.5.12",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "next": "^16.1.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "selfsigned": "^5.5.0",
    "smtp-server": "^3.18.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
