{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "dom",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "EsNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "resolvePackageJsonExports": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "jsx": "react-jsx",
    "incremental": true,
    "inlineSourceMap": true,
    "outDir": "dist",
    "plugins": [
      {
        "name": "next"
      }
    ],
    "customConditions": [
      "development"
    ],
    "esModuleInterop": true
  },
  "include": [
    "next.config.ts",
    "next-env.d.ts",
    "server.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../types/**/*.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
