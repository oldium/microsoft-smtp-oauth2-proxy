{
  "name": "@ms-smtp/ui",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "server": "./dist/bin/server.js"
  },
  "scripts": {
    "dev": "node --conditions development --env-file=../../.env.development --enable-source-maps --disable-warning=ExperimentalWarning --import=@swc-node/register/esm-register ./server.ts",
    "dev:next": "cross-env NODE_ENV=development NEXT_TELEMETRY_DISABLED=1 next dev",
    "build": "cross-env NODE_ENV=production tsc --project ./tsconfig.bin.json",
    "build:next": "cross-env NODE_ENV=production NEXT_TELEMETRY_DISABLED=1 NODE_OPTIONS=--disable-warning=ExperimentalWarning next build",
    "prod": "node --disable-warning=ExperimentalWarning ./dist/bin/server.js"
  },
  "dependencies": {
    "@ms-smtp/common": "0.0.0",
    "@ms-smtp/lib": "0.0.0",
    "@ms-smtp/server": "0.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "geist": "^1.7.1",
    "html-react-parser": "^6.1.1",
    "iron-session": "^8.0.4",
    "lucide-react": "^1.16.0",
    "marked": "^18.0.4",
    "next": "^16.2.6",
    "react": "19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "striptags": "^3.2.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.6",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}
