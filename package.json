{
  "name": "microsoft-smtp-oauth2-proxy",
  "description": "A simple SMTP server with basic authentication that proxies to Microsoft SMTP server with OAuth2 authentication",
  "author": "Oldřich Jedlička",
  "license": "BSD-2-Clause",
  "version": "1.2.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=env.development --env-file=env --enable-source-maps --import=extensionless/register --import=@swc-node/register/esm-register ./server/server.ts",
    "test": "node --import=extensionless/register --experimental-vm-modules --no-warnings node_modules/jest/bin/jest.js --colors --verbose --detectOpenHandles --workerThreads",
    "build": "node --import=extensionless/register --import=@swc-node/register/esm-register ./build.ts",
    "analyze": "node --env-file=env.analyze --import=extensionless/register --import=@swc-node/register/esm-register ./build.ts",
    "prod": "node --env-file=./env --import=extensionless/register ./server/server.js",
    "lint": "next lint"
  },
  "dependencies": {
    "@azure/msal-node": "^3.8.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "clsx": "^2.1.1",
    "connect": "^3.7.0",
    "cookies-next": "^6.1.0",
    "cors": "^2.8.5",
    "crypto-random-string": "^5.0.0",
    "dirty-json": "^0.9.2",
    "email-addresses": "^5.0.0",
    "express": "^5.1.0",
    "extensionless": "^1.9.9",
    "geist": "^1.5.1",
    "html-react-parser": "^5.2.6",
    "ipaddr.js": "^2.2.0",
    "iron-session": "^8.0.4",
    "is-base64": "^1.1.0",
    "localenv": "^0.2.2",
    "lodash": "^4.17.21",
    "lucide-react": "^0.544.0",
    "marked": "^16.3.0",
    "next": "^15.5.4",
    "nocache": "^4.0.0",
    "p-limit": "^7.1.1",
    "react": "19.1.1",
    "react-hot-toast": "^2.6.0",
    "smtp-server": "^3.14.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "striptags": "^3.2.0",
    "tiny-typed-emitter": "^2.1.0",
    "yn": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@next/bundle-analyzer": "^15.5.4",
    "@swc-node/jest": "^1.9.1",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.13.19",
    "@tailwindcss/postcss": "^4.1.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/is-base64": "^1.1.3",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.20",
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.14",
    "@types/react-dom": "^19.1.9",
    "@types/smtp-server": "^3.5.12",
    "@vercel/nft": "^0.30.2",
    "eslint": "^9.36.0",
    "eslint-config-next": "15.5.4",
    "jest": "^30.1.3",
    "postcss": "^8.5.6",
    "selfsigned": "^3.0.1",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  }
}
